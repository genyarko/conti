# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=4096

# --- TrustLayer Engine ---
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
ENGINE_LOG_LEVEL=INFO
ENGINE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Bearer token required on POST /verify* (engine) and POST /upload, /analyze,
# /samples/*/load (demo backend). Leave empty in dev; MUST be set in production.
# Both services should share the same value; frontend sends it via VITE_API_TOKEN.
API_AUTH_TOKEN=

# Token the demo backend presents to the engine upstream (same value as above).
TRUSTLAYER_API_TOKEN=

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# Pipeline tuning
GROUNDING_THRESHOLD_VERIFIED=90
GROUNDING_THRESHOLD_PARTIAL=70
HALLUCINATION_GROUNDING_MAX=50

# --- Demo App ---
DEMO_BACKEND_PORT=8001
TRUSTLAYER_ENGINE_URL=http://localhost:8000

# --- Frontend (Vite) ---
VITE_TRUSTLAYER_API_URL=http://localhost:8000
VITE_DEMO_API_URL=http://localhost:8001
# Bearer token the frontend sends to both services. Must match API_AUTH_TOKEN.
VITE_API_TOKEN=
