# TrustLayer engine URL (core /verify API)
VITE_TRUSTLAYER_API_URL=http://localhost:8000

# Contract reviewer demo backend URL
VITE_CONTRACT_API_URL=http://localhost:8100

# Bearer token sent to both APIs. Leave empty in dev if backends have no API_AUTH_TOKEN;
# required in production. Must match API_AUTH_TOKEN on both services.
VITE_API_TOKEN=
